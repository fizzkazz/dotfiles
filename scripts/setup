#!/usr/bin/env zsh

set -eu
setopt pipefail

START_PWD="$PWD"
SCRIPT_DIR="${0:A:h}"
REPO_DIR="${SCRIPT_DIR:h}"
STOW_DIR="$REPO_DIR/packages"

source "$SCRIPT_DIR/lib/common.zsh"

setup_git=0
git_name=""
git_email=""
setup_gpg=0
setup_ssh=0
input_cache_file="$(dotfiles_input_cache_file setup)"
reuse_cached_inputs=0

gh_target_host() {
  print -r -- "github.com"
}

dotfiles_key_title() {
  local host_part=""
  local email_part=""

  host_part="$(hostname)"
  email_part="${git_email:-$(git config --global user.email 2>/dev/null || true)}"

  [[ -n "$host_part" ]] || host_part="${USER:-dotfiles}"
  [[ -n "$email_part" ]] || email_part="${USER:-dotfiles}@local"

  print -r -- "${host_part}:${email_part}"
}

apply_git_global_config() {
  local key="$1"
  local value="$2"
  log "Git 設定を適用しています: ${key}=${value}"
  git config --global "$key" "$value"
}

gh_token_scopes_from_status() {
  local status_output="$1"
  local line=""
  local scopes=""

  while IFS= read -r line; do
    case "$line" in
      *"Token scopes:"*)
        scopes="${line#*Token scopes: }"
        scopes="${scopes//\'/}"
        scopes="${scopes//[[:space:]]/}"
        print -r -- "$scopes"
        return 0
        ;;
    esac
  done <<< "$status_output"

  return 1
}

ensure_gh_key_registration_auth() {
  local host="$1"
  shift

  local status_output=""
  local granted_scopes=""
  local refresh_scopes=""
  local scope=""
  local login_scopes=""
  local -a required_scopes missing_scopes

  required_scopes=("$@")
  (( ${#required_scopes[@]} )) || return 0
  login_scopes="${(j:,:)required_scopes}"

  command -v gh >/dev/null 2>&1 || die "GitHub 自動登録には gh が必要です"

  log "GitHub 自動登録に必要な gh 認証を確認しています..."
  if ! status_output="$(gh auth status --hostname "$host" --active 2>&1)"; then
    print -u2 -- "$status_output"
    die "GitHub 自動登録には $host への有効な gh 認証が必要です。先に 'gh auth login -h $host -s $login_scopes' を実行してください"
  fi

  if ! granted_scopes="$(gh_token_scopes_from_status "$status_output")"; then
    warn "gh の Token scopes を取得できなかったため、GitHub 自動登録の事前 scope 確認をスキップします"
    return 0
  fi

  for scope in "${required_scopes[@]}"; do
    if [[ ",$granted_scopes," != *",$scope,"* ]]; then
      missing_scopes+=("$scope")
    fi
  done

  if (( ${#missing_scopes[@]} )); then
    refresh_scopes="${(j:,:)missing_scopes}"
    die "gh の認証 scope が不足しています (${(j:, :)missing_scopes})。先に 'gh auth refresh -h $host -s $refresh_scopes' を実行してから、再度 setup を実行してください"
  fi
}

dotfiles_init_output "$START_PWD"

if prompt_reuse_cached_values "$input_cache_file" "前回の setup 設定"; then
  reuse_cached_inputs=1
fi

log "1/3 設定値を準備します"
if (( ! reuse_cached_inputs )); then
  prompt_yes_no setup_git "Git のグローバル設定を適用する"
  if is_truthy "$setup_git"; then
    prompt_required_text git_name "Git user.name"
    prompt_required_text git_email "Git user.email"
  fi
  prompt_yes_no setup_gpg "GPG 鍵をセットアップする"
  prompt_yes_no setup_ssh "SSH 鍵をセットアップする（GitHub 自動登録）"
fi

log "2/3 入力内容を確認します"
if is_truthy "$setup_git"; then
  print -- "  Git設定: 実行する"
  print -- "  Git user.name: ${git_name}"
  print -- "  Git user.email: ${git_email}"
else
  print -- "  Git設定: 実行しない"
fi
if is_truthy "$setup_gpg"; then
  print -- "  GPG: 実行する"
else
  print -- "  GPG: 実行しない"
fi
if is_truthy "$setup_ssh"; then
  print -- "  SSH: 実行する"
else
  print -- "  SSH: 実行しない"
fi

if ! confirm_execution; then
  warn "処理を中止しました"
  exit 0
fi

if ! save_cached_prompt_values "$input_cache_file" \
  setup_git \
  git_name \
  git_email \
  setup_gpg \
  setup_ssh; then
  warn "入力値のキャッシュ保存に失敗しました"
fi

required_gh_scopes=()
if is_truthy "$setup_gpg"; then
  required_gh_scopes+=("write:gpg_key")
fi
if is_truthy "$setup_ssh"; then
  required_gh_scopes+=("write:public_key")
fi
ensure_gh_key_registration_auth "$(gh_target_host)" "${required_gh_scopes[@]}"

log "3/3 設定を実行します"

if is_truthy "$setup_git"; then
  ensure_value git_name
  ensure_value git_email
fi

ensure_repo_files
log "dotfiles 必須ファイルの存在を確認しました"
ensure_homebrew
log "ユーザー別 Homebrew を確認しました"
run_stow_links

if is_truthy "$setup_git"; then
  log "Git のグローバル設定を適用しています..."
  apply_git_global_config "user.name" "$git_name"
  apply_git_global_config "user.email" "$git_email"
  apply_git_global_config "pull.rebase" "false"
  apply_git_global_config "init.defaultBranch" "main"
  apply_git_global_config "alias.sw" "switch"
  apply_git_global_config "alias.nb" "switch -c"
  apply_git_global_config "alias.ad" "add"
  apply_git_global_config "alias.aa" "add -A"
  apply_git_global_config "alias.rs" "reset --soft HEAD^"
  apply_git_global_config "alias.rh" "reset --hard HEAD^"
  apply_git_global_config "alias.br" "branch"
  apply_git_global_config "alias.cm" "commit"
  apply_git_global_config "alias.st" "status"
  apply_git_global_config "alias.pb" '!f() { git push -u origin $(git rev-parse --abbrev-ref HEAD); }; f'
  success "Git のグローバル設定を適用しました"
else
  log "Git のグローバル設定はスキップしました"
fi

if is_truthy "$setup_gpg"; then
  command -v gpg >/dev/null 2>&1 || die "GPG 鍵セットアップには gpg が必要です"
  command -v mktemp >/dev/null 2>&1 || die "GPG 鍵セットアップには mktemp が必要です"
  command -v awk >/dev/null 2>&1 || die "GPG 鍵セットアップには awk が必要です"

  gpg_name=""
  gpg_email=""
  gpg_params=""
  key_id=""
  gpg_pub_file=""
  gpg_add_output=""
  gpg_key_title=""
  gpg_created=0

  if [[ ! -d "$HOME/.gnupg" ]] || [[ -z "$(gpg --list-secret-keys --keyid-format LONG 2>/dev/null)" ]]; then
    log "Git 用 GPG 鍵を作成しています..."
    gpg_name="${git_name:-$(git config --global user.name 2>/dev/null || true)}"
    gpg_email="${git_email:-$(git config --global user.email 2>/dev/null || true)}"
    [[ -n "$gpg_name" ]] || gpg_name="${USER:-dotfiles}"
    [[ -n "$gpg_email" ]] || gpg_email="${USER:-dotfiles}@local"

    gpg_params="$(mktemp -t dotfiles-gpg.XXXXXX)"
    cat > "$gpg_params" <<EOF
%no-protection
Key-Type: eddsa
Key-Curve: ed25519
Subkey-Type: ecdh
Subkey-Curve: cv25519
Name-Real: $gpg_name
Name-Email: $gpg_email
Expire-Date: 0
%commit
EOF
    gpg --batch --generate-key "$gpg_params"
    rm -f "$gpg_params"
    gpg_created=1
  else
    success "既存の GPG 鍵を検出したため、新規作成をスキップしました"
  fi

  key_id="$(gpg --list-secret-keys --with-colons --keyid-format LONG | awk -F: '$1=="sec"{print $5; exit}')"
  if [[ -z "$key_id" ]]; then
    warn "GPG 鍵IDを自動取得できませんでした"
  else
    git config --global user.signingkey "$key_id"
    gpg_pub_file="$(mktemp -t dotfiles-gpg-pub.XXXXXX)"
    gpg --armor --export "$key_id" > "$gpg_pub_file"
    gpg_key_title="$(dotfiles_key_title)"

    log "GPG 公開鍵を GitHub に自動登録しています（title: ${gpg_key_title}）..."
    if gpg_add_output="$(gh gpg-key add "$gpg_pub_file" --title "$gpg_key_title" 2>&1)"; then
      success "GPG 公開鍵の GitHub 登録が完了しました"
    elif [[ "$gpg_add_output" == *"already in use"* ]]; then
      success "GPG 公開鍵は既に GitHub に登録済みです"
    else
      warn "GPG 公開鍵の GitHub 登録に失敗しました。手動登録用に鍵を表示します"
      print -u2 -- "$gpg_add_output"
      gpg --armor --export "$key_id"
    fi
    rm -f "$gpg_pub_file"

    if (( gpg_created )); then
      success "GPG 鍵の作成と Git 設定が完了しました"
    else
      success "GPG 鍵の Git 設定を適用しました"
    fi
  fi
else
  log "GPG 鍵のセットアップはスキップしました"
fi

if is_truthy "$setup_ssh"; then
  command -v ssh-keygen >/dev/null 2>&1 || die "SSH 鍵セットアップには ssh-keygen が必要です"
  if [[ ! -f "$HOME/.ssh/id_ed25519.pub" ]]; then
    ssh_key_title=""
    ssh_add_output=""
    ssh_email=""
    log "SSH 鍵を作成しています..."
    mkdir -p "$HOME/.ssh"
    ssh_email="${git_email:-$(git config --global user.email 2>/dev/null || true)}"
    if [[ -n "${ssh_email}" ]]; then
      ssh-keygen -t ed25519 -f "$HOME/.ssh/id_ed25519" -N "" -C "$ssh_email"
    else
      ssh-keygen -t ed25519 -f "$HOME/.ssh/id_ed25519" -N ""
    fi
    ssh_key_title="$(dotfiles_key_title)"
    log "SSH 公開鍵を GitHub に自動登録しています（title: ${ssh_key_title}）..."
    if ssh_add_output="$(gh ssh-key add "$HOME/.ssh/id_ed25519.pub" --title "$ssh_key_title" 2>&1)"; then
      success "SSH 鍵の作成と GitHub への登録が完了しました"
    elif [[ "$ssh_add_output" == *"key is already in use"* ]]; then
      success "SSH 公開鍵は既に GitHub に登録済みです"
    else
      warn "SSH 公開鍵の GitHub 登録に失敗しました。手動登録用に鍵を表示します"
      print -u2 -- "$ssh_add_output"
      cat "$HOME/.ssh/id_ed25519.pub"
    fi
  else
    success "既存の SSH 鍵を検出したため、新規作成をスキップしました"
  fi
else
  log "SSH 鍵のセットアップはスキップしました"
fi
